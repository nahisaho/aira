{
  "name": "aira",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AIRA - AI Research Administrator",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:wasm": "cd wasm && wasm-pack build --target web --out-dir ../frontend/src/wasm/pkg",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npx playwright test",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "docker:build": "docker build -t aira:latest .",
    "docker:run": "docker run -p 3000:3000 -v aira-data:/app/data -v aira-projects:/app/projects aira:latest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "archiver": "^7.0.1",
    "chokidar": "^5.0.0",
    "hono": "^4.7.0",
    "sql.js": "^1.12.0",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
